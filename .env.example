# ServerConfiguration — пример конфигурации
#
# Заполните значения и сохраните файл как .env рядом со скриптами.
# Скрипты:
# - SOCKS (Shadowsocks): ./socks_second_server.sh
# - tun2socks:           ./tun2socks_install.sh

# --- SOCKS / Shadowsocks (второй сервер) ---

# Список IP-адресов (CSV), которым разрешён доступ к Shadowsocks порту.
# Пример с несколькими IP:
ALLOWED_IPS="147.45.143.194,95.140.159.63"

# Порт, на котором будет слушать Shadowsocks (TCP+UDP)
SS_SERVER_PORT=6666

# Пароль Shadowsocks
SS_PASSWORD="changeMeStrongPassword"

# Метод шифрования (рекомендуемое значение из исходной инструкции)
SS_METHOD="chacha20-ietf-poly1305"

# Таймаут (сек)
SS_TIMEOUT=86400


# --- tun2socks (маршрутизация через EU Shadowsocks) ---

# IP EU сервера Shadowsocks, через который будет идти туннель
TUN_SSIP="44.221.188.49"

# Порт Shadowsocks на EU сервере
TUN_SSPORT=6666

# Пароль Shadowsocks на EU сервере
TUN_SSPASSWORD="changeMeStrongPassword"

# Метод шифрования для EU сервера Shadowsocks
TUN_SSMETHOD="chacha20-ietf-poly1305"

# (опционально) Сетевой интерфейс сервера. Если не задан — скрипт определит автоматически
# через `ip route show default` (обычно eth0).
#TUN2SOCKS_IFACE="eth0"

# (опционально) Имя TUN-устройства. По умолчанию: tun0
#TUN2SOCKS_TUN_DEV="tun0"

# (опционально) IP/маска для TUN-интерфейса (локальный адрес на сервере).
# Это НЕ внешний IP и НЕ адрес EU сервера.
# По умолчанию: 192.168.0.33/24
#TUN2SOCKS_TUN_ADDR="192.168.0.33/24"
