# vpn_install package config
# Domain pointing to this VPS (A/AAAA).
DOMAIN=sbercloud.admishakov.ru

# Email for Let's Encrypt (only used if ENABLE_LETSENCRYPT=1)
EMAIL=admishakov.armeniacard@gmail.com

# Use Let's Encrypt certs for Trojan/Hysteria2 (recommended)
# If your provider blocks inbound :80 and you can't do DNS-01, set ENABLE_LETSENCRYPT=0.
ENABLE_LETSENCRYPT=1

# If ENABLE_LETSENCRYPT=0, allow generating a self-signed certificate (less stealthy, but works).
ALLOW_SELF_SIGNED=1

# TrustTunnel stability: require TrustTunnel to use a valid Let's Encrypt cert.
# If 1, setup will FAIL if certbot cannot issue a cert that includes TRUSTTUNNEL_DOMAIN.
# Common cause of failure: inbound TCP :80 blocked by provider firewall/security group.
REQUIRE_TRUSTTUNNEL_LE=1

# Ports
# Public entrypoint for ALL protocols (TCP/UDP). Typically 443 on the VPS.
PORT_PUBLIC=443

# Internal ports (loopback only). Public traffic is multiplexed on PORT_PUBLIC.
# These MUST NOT overlap with PORT_PUBLIC to avoid bind conflicts.
PORT_VLESS_REALITY_TCP=8443
PORT_TROJAN_TLS_TCP=2053
PORT_HYSTERIA2_QUIC_UDP=8443

# Users
VLESS_UUID=
TROJAN_PASSWORD=
HYSTERIA2_PASSWORD=

# Reality camouflage target (must be reachable/not blocked from the censored network)
# Reality camouflage target (must be reachable/not blocked from the censored network)
# Default: Yandex (RU)
REALITY_SERVER_NAME=www.yandex.ru
REALITY_HANDSHAKE_SERVER=www.yandex.ru
REALITY_HANDSHAKE_PORT=443

# Linux user that will run sing-box (will be created if missing)
SINGBOX_USER=singbox

# TrustTunnel Configuration
TRUSTTUNNEL_DOMAIN=tt.example.com
TRUSTTUNNEL_USERNAME=admin
# TRUSTTUNNEL_PASSWORD=auto-generated-if-empty

# Nginx Fallback Port
PORT_NGINX=8080
PORT_TRUSTTUNNEL=9443
