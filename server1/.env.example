# server1 (разрешённый/RU сервер)
# Используется скриптом: ../tun2socks_install.sh

# IP/домен зарубежного (EU) сервера с Shadowsocks
TUN_SSIP="44.221.188.49"

# Порт Shadowsocks на EU сервере
TUN_SSPORT=6666

# Пароль Shadowsocks на EU сервере
TUN_SSPASSWORD="changeMeStrongPassword"

# Метод шифрования для EU сервера Shadowsocks
TUN_SSMETHOD="chacha20-ietf-poly1305"

# (опционально) Если не задан — интерфейс определяется автоматически по default route
#TUN2SOCKS_IFACE="eth0"

# (опционально) TUN-устройство и его локальный адрес (НЕ внешний IP)
#TUN2SOCKS_TUN_DEV="tun0"
#TUN2SOCKS_TUN_ADDR="192.168.0.33/24"
