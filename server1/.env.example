# server1 (клиентская сторона: ss-local + tun2socks)

# Shadowsocks server (server2)
TUN_SSIP="89.167.112.24"
TUN_SSPORT=6666
TUN_SSPASSWORD="testPassword"
TUN_SSMETHOD="chacha20-ietf-poly1305"
TUN_TIMEOUT=86400

# Local SOCKS5 exposed by ss-local
LOCAL_SOCKS_ADDR="127.0.0.1"
LOCAL_SOCKS_PORT=1080

# Primary egress interface on server1; auto-detected if empty
#TUN2SOCKS_IFACE="eth0"

# TUN device settings
TUN2SOCKS_TUN_DEV="tun0"
TUN2SOCKS_TUN_ADDR="198.18.0.1/15"
TUN2SOCKS_MTU=1500

# Full-tunnel mode only.
# Current host DNS resolvers are auto-detected and bypassed automatically.
# Add extra IPv4 addresses/subnets to keep outside the tunnel, comma-separated.
# Example: FULL_TUNNEL_BYPASS_IPS="1.2.3.4,5.6.7.0/24"
FULL_TUNNEL_BYPASS_IPS=""
