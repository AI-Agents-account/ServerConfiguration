# vpn_install package config
# Domain pointing to this VPS (A/AAAA).
DOMAIN=sbercloud.admishakov.ru

# Email for Let's Encrypt (only used if ENABLE_LETSENCRYPT=1)
EMAIL=admishakov.armeniacard@gmail.com

# Use Let's Encrypt certs for Trojan/Hysteria2 (recommended)
# If your provider blocks inbound :80 and you can't do DNS-01, set ENABLE_LETSENCRYPT=0.
ENABLE_LETSENCRYPT=1

# If ENABLE_LETSENCRYPT=0, allow generating a self-signed certificate (less stealthy, but works).
ALLOW_SELF_SIGNED=1

# Ports
PORT_VLESS_REALITY_TCP=443
PORT_TROJAN_TLS_TCP=2053
PORT_HYSTERIA2_QUIC_UDP=443

# Users
VLESS_UUID=
TROJAN_PASSWORD=
HYSTERIA2_PASSWORD=

# Reality camouflage target (must be reachable/not blocked from the censored network)
# Reality camouflage target (must be reachable/not blocked from the censored network)
# Default: Yandex (RU)
REALITY_SERVER_NAME=www.yandex.ru
REALITY_HANDSHAKE_SERVER=www.yandex.ru
REALITY_HANDSHAKE_PORT=443

# Linux user that will run sing-box (will be created if missing)
SINGBOX_USER=singbox
