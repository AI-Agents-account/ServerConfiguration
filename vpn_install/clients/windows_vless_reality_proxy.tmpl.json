{
  "log": {"level": "info"},
  "inbounds": [
    {"type": "mixed", "tag": "in", "listen": "127.0.0.1", "listen_port": 1080}
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "out",
      "server": "__SERVER__",
      "server_port": __PORT__,
      "uuid": "__UUID__",
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "__REALITY_SNI__",
        "alpn": ["h2", "http/1.1"],
        "utls": {"enabled": true, "fingerprint": "chrome"},
        "reality": {
          "enabled": true,
          "public_key": "__REALITY_PUBKEY__",
          "short_id": "__REALITY_SHORTID__"
        }
      }
    }
  ],
  "route": {"final": "out"}
}
